@inherits LayoutComponentBase
@inject IWebHostEnvironment Env

<div class="side">
    @if (ErDemo)
    {
        <div class="demobanner">Demo-modus — lokal kjøring uten Entra/Azure SQL. <a href="/demo">Bytt persona</a></div>
    }
    <header class="topplinje">
        <a class="merkenavn" href="/">Årshjul for budsjettfrister</a>
        <nav class="hovednav">
            <NavLink href="/" Match="NavLinkMatch.All">Nå</NavLink>
            <NavLink href="/kalender">Kalender</NavLink>
            <NavLink href="/aarshjul">Årshjul</NavLink>
            <AuthorizeView Policy="@Autorisasjon.KanForeslaa">
                <NavLink href="/forslag/mine">Mine forslag</NavLink>
                <VarselTeller />
            </AuthorizeView>
            <AuthorizeView Policy="@Autorisasjon.ErAdministrator">
                <NavLink href="/admin/ko">Kø</NavLink>
                <NavLink href="/admin/frister">Frister</NavLink>
                <NavLink href="/admin/generer">Generér</NavLink>
                <NavLink href="/admin/mal">Årsmal</NavLink>
                <NavLink href="/admin/innsyn">Innsyn</NavLink>
                <NavLink href="/admin/eksport">Eksporter</NavLink>
            </AuthorizeView>
        </nav>
        <div class="bruker">
            <AuthorizeView>
                <Authorized>
                    <span class="brukernavn">@context.User.Identity?.Name</span>
                    <a href="@LoggUtUrl">Logg ut</a>
                </Authorized>
                <NotAuthorized>
                    <a href="@LoggInnUrl">Logg inn</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </header>

    <main class="innhold">
        @Body
    </main>
</div>

@code {
    private bool ErDemo => Env.IsEnvironment("Demo");
    private string LoggInnUrl => ErDemo ? "/demo" : "MicrosoftIdentity/Account/SignIn";
    private string LoggUtUrl => ErDemo ? "/demo/logg-ut" : "MicrosoftIdentity/Account/SignOut";
}

<div id="blazor-error-ui" data-nosnippet>
    En uventet feil oppstod.
    <a href="." class="reload">Last på nytt</a>
    <span class="dismiss">🗙</span>
</div>
